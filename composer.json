    "require": {
        "php": "^8.3",
        "twig/twig": "^3.21.0",
        "ext-curl": "*",
        "ext-exif": "*",
        "ext-gd": "*",
        "ext-pdo": "*",
        "ext-mysqli": "*",
        "ext-apcu": "*",
        "symfony/http-client": "^7.3.0",
        "monolog/monolog": "^3.8.1"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "phpstan/phpstan": "^2.1.0",
        "jetbrains/phpstorm-attributes": "^1.2",
        "rector/rector": "^2.1.0",
        "friendsofphp/php-cs-fixer": "^3.88.0"
    },
    "config": {
        "platform": {
            "php": "8.4.2",
            "ext-curl": "8.4.2",
            "ext-exif": "832.0",
            "ext-gd": "8.4.2",
            "ext-mysqli": "8.4.2",
            "ext-pdo": "8.4.2"
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src",
            "App\\Lib\\Database\\": "src/lib/database",
            "App\\Lib\\Hook\\": "src/lib/Hook",
            "App\\Lib\\Log\\": "src/lib/Log",
            "App\\Lib\\Task\\": "src/lib/Task",
            "App\\Lib\\Util\\": "src/lib/util"
        }
    }
}
