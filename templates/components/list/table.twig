<div class="cm-list-table cm-list-table-auto">
  <table border="0" cellpadding="0" cellspacing="0">
    <thead>
    <tr>
      {% for column in columns %}
        <th
          {% if column.key %}
            title="{{ column.key }}"
          {% endif %}
          {% if column.type in ['html-numeric', 'numeric', 'quantity', 'quantity3', 'price'] %}
            class="td-numeric"
          {% endif %}
        >
          {{ column.name }}
        </th>
      {% endfor %}
      {% if rowAction or tableAction %}
        <th class="td-actions">Actions</th>
      {% endif %}
    </tr>
    </thead>
    <tbody>
      {% for attendee in attendees %}
      {{ include('components/list/row.twig', {
        'rowAction': rowAction,
        'attendee': attendee,
      }, with_context = false) }}
      {% endfor %}
    </tbody>
    {% if tableAction %}
      <tfoot>
      <tr>
        <th colspan="{{ columns|length + 1 }}" class="td-actions">
          {% if 'add' in tableAction %}
            <form method="get" target="_blank" action="/admin/attendee/edit.php">
              <input type="submit" value="Add" class="button add-button">
            </form>
          {% endif %}
        </th>
      </tr>
      </tfoot>
    {% endif %}
  </table>
</div>
